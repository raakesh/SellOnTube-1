---
import Layout from '~/layouts/PageLayout.astro';
import { Image } from 'astro:assets';
import { SITE } from 'astrowind:config';

import sathyanandPhoto from '~/assets/images/team/Sathya Profile Photo.jpg';
import gauthamPhoto from '~/assets/images/team/Gautham Profile Photo.jpg';
import heroImage from '~/assets/images/workspace-overview.jpg';
import searchIntentImage from '~/assets/images/person-searching-laptop.jpg';
import productionImage from '~/assets/images/content-creation-setup.jpg';
import economicsImage from '~/assets/images/data-analysis-charts.jpg';

const metadata = {
  title: 'About Us',
  description: 'Meet the founders of SellOnTube. Sathyanand and Gautham built a YouTube acquisition service for B2B businesses that want predictable leads, not just views.',
  robots: { index: true, follow: true },
};

const siteUrl = SITE.site || 'https://sellontube.com';

const aboutSchema = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "name": "About Us",
  "url": `${siteUrl}/about`,
  "description": "Meet the founders of SellOnTube, a YouTube content strategy and production service for B2B businesses.",
  "publisher": {
    "@type": "Organization",
    "name": "SellOnTube",
    "url": siteUrl
  }
};

const founders = [
  {
    name: 'Sathyanand S',
    photo: sathyanandPhoto,
    photoAlt: 'Sathyanand S, Co-Founder of SellOnTube',
    role: 'Co-Founder',
    bio: 'Sathyanand spent years helping B2B businesses trace how their best customers actually found them. He kept seeing the same pattern: YouTube had real search demand in almost every niche, but most businesses were not building for it. He co-founded SellOnTube to turn that into a repeatable acquisition system.',
    linkedin: 'https://www.linkedin.com/in/sathyanands/',
    twitter: 'https://x.com/SathyaHQ',
    twitterHandle: '@SathyaHQ',
  },
  {
    name: 'Gautham',
    photo: gauthamPhoto,
    photoAlt: 'Gautham, Co-Founder of SellOnTube',
    role: 'Co-Founder',
    bio: 'Gautham built the research and diagnostic framework behind SellOnTube. Before a single video gets made, he maps the search demand, stress-tests the economics, and figures out whether YouTube can genuinely pay for itself. If it cannot, he says so.',
    linkedin: 'https://www.linkedin.com/in/mindcharting/',
    twitter: 'https://x.com/MindCharting',
    twitterHandle: '@MindCharting',
  },
];

const pillars = [
  {
    title: 'Search intent first',
    description: 'Every video starts with what buyers are already searching for. We work backwards from demand, not from a content calendar.',
    image: searchIntentImage,
    imageAlt: 'Person researching on laptop, representing search intent research',
  },
  {
    title: 'No recording required',
    description: 'Professional voiceover, editing, and publishing. You review and approve. We handle everything else.',
    image: productionImage,
    imageAlt: 'Content creation and video production setup',
  },
  {
    title: 'Economics first',
    description: 'If the math does not work in the diagnostic, we do not take you on. We only proceed when YouTube can realistically pay for itself.',
    image: economicsImage,
    imageAlt: 'Data analysis charts representing business economics and ROI',
  },
];
---

<Layout metadata={metadata}>
  <script type="application/ld+json" set:html={JSON.stringify(aboutSchema)} />

  <!-- Hero -->
  <section class="py-16 sm:py-20 text-center">
    <div class="max-w-3xl mx-auto px-4">
      <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight">
        About Us
      </h1>
      <p class="mt-5 text-base sm:text-lg text-gray-600 dark:text-slate-300 max-w-2xl mx-auto">
        Most B2B founders who try YouTube have the right instincts. They make videos on topics their buyers care about, stay consistent for a while, and then stop when nothing comes of it.
      </p>
      <p class="mt-3 text-base sm:text-lg text-gray-600 dark:text-slate-300 max-w-2xl mx-auto">
        The problem is rarely the content. It is the strategy. YouTube works as an acquisition channel when you treat it like one, starting with search demand and working backwards. That is what we built SellOnTube to do.
      </p>
    </div>
  </section>

  <!-- Hero image -->
  <div class="max-w-5xl mx-auto px-4 pb-16">
    <Image
      src={heroImage}
      alt="SellOnTube workspace showing the YouTube acquisition strategy process"
      width={1200}
      height={600}
      class="w-full rounded-2xl object-cover"
    />
  </div>

  <!-- Pillars with images -->
  <section class="py-12 sm:py-16 bg-slate-50 dark:bg-slate-800/50">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center mb-10">
        <p class="text-sm font-medium uppercase tracking-wide text-emerald-600 dark:text-emerald-400 mb-2">How we work</p>
        <h2 class="text-2xl sm:text-3xl font-bold tracking-tight">Three things we refuse to compromise on</h2>
      </div>
      <div class="grid sm:grid-cols-3 gap-6">
        {pillars.map((pillar) => (
          <div class="bg-white dark:bg-slate-900 rounded-2xl overflow-hidden border border-slate-200 dark:border-slate-700">
            <Image
              src={pillar.image}
              alt={pillar.imageAlt}
              width={400}
              height={220}
              class="w-full h-44 object-cover"
            />
            <div class="p-6">
              <h3 class="text-base font-semibold text-gray-900 dark:text-white mb-2">{pillar.title}</h3>
              <p class="text-sm text-gray-600 dark:text-slate-400 leading-relaxed">{pillar.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="py-16 sm:py-20">
    <div class="max-w-4xl mx-auto px-4">
      <div class="text-center mb-12">
        <p class="text-sm font-medium uppercase tracking-wide text-emerald-600 dark:text-emerald-400 mb-2">The team</p>
        <h2 class="text-2xl sm:text-3xl font-bold tracking-tight">The people behind the work</h2>
      </div>

      <div class="grid sm:grid-cols-2 gap-8">
        {founders.map((founder) => (
          <div class="bg-white dark:bg-slate-900 rounded-2xl p-8 border border-slate-200 dark:border-slate-700 flex flex-col items-center text-center">
            <Image
              src={founder.photo}
              alt={founder.photoAlt}
              width={96}
              height={96}
              class="w-24 h-24 rounded-full object-cover object-top mb-5 flex-shrink-0"
            />
            <h3 class="text-xl font-semibold text-gray-900 dark:text-white">{founder.name}</h3>
            <p class="text-sm text-emerald-600 dark:text-emerald-400 mt-1 mb-4">{founder.role}</p>
            <p class="text-sm text-gray-600 dark:text-slate-400 leading-relaxed mb-6">{founder.bio}</p>

            <div class="flex items-center gap-4 mt-auto">
              <a
                href={founder.linkedin}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`${founder.name} on LinkedIn`}
                class="flex items-center gap-1.5 text-sm text-gray-500 dark:text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
                LinkedIn
              </a>
              <a
                href={founder.twitter}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={`${founder.name} on X`}
                class="flex items-center gap-1.5 text-sm text-gray-500 dark:text-slate-400 hover:text-gray-900 dark:hover:text-white transition-colors"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.741l7.73-8.835L1.254 2.25H8.08l4.259 5.631 5.905-5.631zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                </svg>
                {founder.twitterHandle}
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-14 sm:py-16">
    <div class="max-w-3xl mx-auto px-4 text-center space-y-4">
      <h2 class="text-2xl sm:text-3xl font-semibold tracking-tight">
        Ready to find out if YouTube makes sense for your business?
      </h2>
      <p class="text-base text-gray-600 dark:text-slate-300">
        Start with a diagnostic call. We will run the numbers, map the search demand, and tell you plainly whether YouTube should be part of your acquisition mix.
      </p>
      <div class="mt-6 flex justify-center">
        <a
          href="https://cal.com/gautham-8bdvdx/30min"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center rounded-full px-6 py-2.5 text-sm font-semibold
                 bg-black text-white hover:bg-gray-900 dark:bg-white dark:text-slate-900 dark:hover:bg-slate-100
                 transition-colors"
        >
          Book a diagnostic call
        </a>
      </div>
    </div>
  </section>

</Layout>
